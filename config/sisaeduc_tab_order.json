{
  "description": "Ordem baseada na tela de cadastro mostrada no screenshot do Sisaeduc. Cada item representa uma parada de Tab a partir do primeiro campo Nome.",
  "fields": [
    { "field_id": "nome", "csv_column": "aluno_nome", "action_type": "text" },
    { "field_id": "telefone", "csv_column": "telefone_contato", "action_type": "text" },
