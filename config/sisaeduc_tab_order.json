    { "field_id": "vulnerabilidade_social", "csv_column": "vulnerabilidade_social", "action_type": "choice", "choice_fallback": "type_value", "default": "Não", "extra_tabs": 1 },

    { "field_id": "nome_mae", "csv_column": "mae_nome", "action_type": "text" },
    { "field_id": "profissao_mae", "csv_column": "mae_profissao", "action_type": "text" },
    { "field_id": "rg_mae", "csv_column": "mae_rg", "action_type": "text" },

    { "field_id": "nome_pai", "csv_column": "pai_nome", "action_type": "text" },
    { "field_id": "profissao_pai", "csv_column": "pai_profissao", "action_type": "text" },
    { "field_id": "rg_pai", "csv_column": "pai_rg", "action_type": "text" },

    { "field_id": "outro_responsavel", "action_type": "skip", "tab_after": false },

    { "field_id": "registro_nascimento_casamento", "csv_column": "certidao_numero", "action_type": "text" },
