    { "field_id": "nome_social", "csv_column": "aluno_nome_social", "action_type": "text" },

    { "field_id": "utiliza_transporte", "csv_column": "utiliza_transporte", "action_type": "choice", "choice_fallback": "type_value", "default": "Não", "extra_tabs": 1 },
